{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@api/*": [
                "./src/api/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@context/*": [
                "./src/context/*"
            ],
            "@hooks/*": [
                "./src/hooks/*"
            ],
            "@i18n/*": [
                "./src/i18n/*"
            ],
            "@styles/*": [
                "./src/styles/*"
            ],
            "@app-types": [
                "./src/types.ts"
            ],
            "@views/*": [
                "./src/views/*"
            ]
        },
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        ".next/types/**/*.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        ".next/dev/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
